rules_version = '2';

// ─── Firestore Security Rules ──────────────────────────────────────────────
// Copy this into: Firebase Console → Firestore Database → Rules tab → Publish
//
// What this does: each signed-in user can ONLY read/write their own document
// at users/{their-own-uid}. Nobody can read or write anyone else's data,
// including friends sharing this same deployed app.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
